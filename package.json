{
  "name": "sunshine-virtual-display",
  "version": "1.0.0",
  "description": "A CLI tool to create native macOS virtual displays and automatically provision Sunshine for headless streaming.",
  "main": "dist/bundle.cjs",
  "bin": {
    "sunshine-vd": "dist/bundle.cjs"
  },
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "build": "esbuild index.ts --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs --external:node-mac-virtual-display",
    "package": "pkg . --targets node22-macos-x64,node22-macos-arm64 --out-path bin"
  },
  "pkg": {
    "assets": [
      "node_modules/node-mac-virtual-display/build/Release/virtual_display.node",
      "node_modules/node-mac-virtual-display/dist/index.js",
      "node_modules/bindings/index.js",
      "node_modules/file-uri-to-path/index.js"
    ]
  },
  "keywords": [
    "sunshine",
    "virtual-display",
    "macos",
    "headless",
    "streaming"
  ],
  "author": "Pietro Marques",
  "license": "GPL-3.0-only",
  "dependencies": {
    "kleur": "^4.1.5",
    "node-mac-virtual-display": "^1.0.13",
    "ora": "^9.4.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "@types/ora": "^3.1.0",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^4.1.6",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
